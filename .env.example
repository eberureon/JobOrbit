# Copy this file to .env and adjust as needed.
# docker compose automatically reads .env in the project directory.

# Host port to expose the app on. The container always listens on 3000 internally.
PORT=9000

# SQLite database path (mounted volume in Docker).
DATABASE_URL=./data/joborbit.db

# Timezone inside the container (used for date display in logs).
TZ=Etc/UTC
