# Copy this file to .env and adjust each variable as needed.
# For different environments, you can also create per-environment files:
#   .env.development  — loaded when NODE_ENV=development
#   .env.production   — loaded when NODE_ENV=production
# Docker Compose picks them up via this block in compose.yaml:
#   env_file:
#     - .env.${NODE_ENV:-production}
#
# To get started quickly:
#   1. cp .env.example .env.development
#   2. Open .env.development and adjust values
#   3. Run with: NODE_ENV=development docker compose up

# Node environment mode. Controls dev/prod behavior like error handling and logging.
NODE_ENV=development

# IP address the dev server binds to. Use 0.0.0.0 to accept connections from
# any network interface (required for Docker).
HOST=0.0.0.0

# Host port to expose the app on. The container always listens on 3000 internally.
PORT=9000

# SQLite database path (mounted volume in Docker).
DATABASE_URL=./data/joborbit.db

# Timezone inside the container (used for date display in logs).
TZ=Etc/UTC
